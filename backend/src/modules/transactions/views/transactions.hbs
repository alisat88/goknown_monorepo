{{> header}}

    <font face="'Poppins', sans-serif" color="#1a1a1a" style="font-size: 38px; line-height: 60px; font-weight: 300; letter-spacing: -1.5px;">
      <span style="font-family: 'Poppins', Arial, Tahoma, Geneva, sans-serif; color: #1a1a1a; font-size: 32px; line-height: 60px; font-weight: 300; letter-spacing: -1.5px;">{{touser_name}}, you receveid a new transaction</span>
    </font>

  <div style="height: 33px; line-height: 33px; font-size: 31px;">&nbsp;</div>

<table cellpadding="0" cellspacing="0" border="0" width="88%" style="width: 88% !important; min-width: 88%; max-width: 88%;">
    <tr>
      <td align="left" valign="top">
        <font face="'Poppins', sans-serif" color="#1a1a1a" style="font-size: 14px; line-height: 30px; text-decoration: none; white-space: nowrap; font-weight: bold;">
          <span style="font-family: 'Poppins', Arial, Tahoma, Geneva, sans-serif; color: #1a1a1a; font-size: 14px; line-height: 30px; text-decoration: none; white-space: nowrap; font-weight: bold;">Date: {{date}}</span>
        </font>
      </td>
    </tr>
    <tr>
      <td align="left" valign="top">
        <font face="'Poppins', sans-serif" color="#1a1a1a" style="font-size: 14px; line-height: 30px; text-decoration: none; white-space: nowrap; font-weight: bold;">
          <span style="font-family: 'Poppins', Arial, Tahoma, Geneva, sans-serif; color: #1a1a1a; font-size: 14px; line-height: 30px; text-decoration: none; white-space: nowrap; font-weight: bold;">From: {{formuser_name}}  ({{formuser_email}})</span>
        </font>
      </td>
    </tr>
    <tr>
      <td align="left" valign="top">
        <font face="'Poppins', sans-serif" color="#1a1a1a" style="font-size: 14px; line-height: 30px; text-decoration: none; white-space: nowrap; font-weight: bold;">
          <span style="font-family: 'Poppins', Arial, Tahoma, Geneva, sans-serif; color: #1a1a1a; font-size: 14px; line-height: 30px; text-decoration: none; white-space: nowrap; font-weight: bold;">Amount: {{amount}}</span>
        </font>
      </td>
    </tr>
     <tr>
      <td align="left" valign="top">
        <font face="'Poppins', sans-serif" color="#1a1a1a" style="font-size: 14px; line-height: 30px; text-decoration: none; white-space: nowrap; font-weight: bold;">
          <span style="font-family: 'Poppins', Arial, Tahoma, Geneva, sans-serif; color: #1a1a1a; font-size: 14px; line-height: 30px; text-decoration: none; white-space: nowrap; font-weight: bold;">Message: {{message}}</span>
        </font>
      </td>
    </tr>
</table>

  <div style="height: 33px; line-height: 33px; font-size: 31px;">&nbsp;</div>
  <div style="height: 33px; line-height: 33px; font-size: 31px;">&nbsp;</div>

{{> footer}}
