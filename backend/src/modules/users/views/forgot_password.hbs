{{> header}}
  <table cellpadding="0" cellspacing="0" border="0" width="88%" style="width: 88% !important; min-width: 88%; max-width: 88%;">
    <tr>
      <td align="left" valign="top">
          <font face="'Poppins', sans-serif" color="#1a1a1a" style="font-size: 32px; line-height: 60px; font-weight: 300; letter-spacing: -1.5px;">
            <span style="font-family: 'Poppins', Arial, Tahoma, Geneva, sans-serif; color: #1a1a1a; font-size: 32px; line-height: 60px; font-weight: 300; letter-spacing: -1.5px;">Hey {{name}},</span>
          </font>
          <div style="height: 33px; line-height: 33px; font-size: 31px;">&nbsp;</div>
          <font face="'Poppins', sans-serif" color="#585858" style="font-size: 18px; line-height: 32px;">
            <span style="font-family: 'Poppins', Arial, Tahoma, Geneva, sans-serif; color: #585858; font-size: 18px; line-height: 32px;">Resetting your password is easy. Just press the button below and follow the instructions. We'll have you up and running in no time.</span>
          </font>

          <div style="height: 33px; line-height: 33px; font-size: 31px;">&nbsp;</div>
          <table class="mob_btn" cellpadding="0" cellspacing="0" border="0" style="background: #00007d; border-radius: 4px;">
            <tr>
                <td align="center" valign="top">
                  <a href={{link}} target="_blank" style="display: block; border: 1px solid #00007d; border-radius: 4px; padding: 12px 23px; font-family: 'Poppins', Arial, Verdana, Tahoma, Geneva, sans-serif; color: #ffffff; font-size: 20px; line-height: 30px; text-decoration: none; white-space: nowrap; font-weight: 600;">
                      <font face="'Poppins', sans-serif" color="#ffffff" style="font-size: 20px; line-height: 30px; text-decoration: none; white-space: nowrap; font-weight: 600;">
                        <span style="font-family: 'Poppins', Arial, Verdana, Tahoma, Geneva, sans-serif; color: #ffffff; font-size: 20px; line-height: 30px; text-decoration: none; white-space: nowrap; font-weight: 600;">Reset&nbsp;password</span>
                      </font>
                  </a>
                </td>
            </tr>
          </table>
          <div style="height: 33px; line-height: 33px; font-size: 31px;">&nbsp;</div>
          <font face="'Poppins', sans-serif" color="#585858" style="font-size: 14px; line-height: 24px;">
            <span style="font-family: 'Poppins', Arial, Tahoma, Geneva, sans-serif; color: #585858; font-size: 14px; line-height: 24px;">If the button doesn't work, copy and paste the link below into your browser:</span>
          </font>
          <div style="height: 10px; line-height: 10px; font-size: 8px;">&nbsp;</div>
          <font face="'Poppins', sans-serif" color="#00007d" style="font-size: 14px; line-height: 24px; word-break: break-all;">
            <a href="{{link}}" style="color: #00007d; text-decoration: underline;">
              <span style="font-family: 'Poppins', Arial, Tahoma, Geneva, sans-serif; color: #00007d; font-size: 14px; line-height: 24px; word-break: break-all;">{{link}}</span>
            </a>
          </font>
          <div style="height: 75px; line-height: 75px; font-size: 73px;">&nbsp;</div>
      </td>
    </tr>
  </table>
{{> footer }}
