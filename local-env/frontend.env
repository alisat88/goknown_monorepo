########################################
# 🟢 React App Environment Settings
########################################

REACT_APP_ENVIRONMENT=development # Options: development | staging | production
REACT_APP_SHOW_DEBUG=true # Set to false to hide all UI debug info and suppress console.log

########################################
# 🔵 Backend API Endpoints
########################################

# API URLs for different environments
# Note: Use localhost for browser access, backend.local-env.orb.local only works within Docker network
REACT_APP_PRODUCTION_API=http://localhost:3333/
REACT_APP_DEVELOPMENT_API=http://localhost:3333/
REACT_APP_STAGING_API=http://localhost:3333/
REACT_APP_BALANCE_API=http://localhost:3333/

########################################
# 🟠 Build Options
########################################

GENERATE_SOURCEMAP=false # If true, source maps will be generated during build

########################################
# 🟣 Bypass Options (Testing Purposes)
########################################

REACT_APP_BYPASS_SMS_2FA=true # If true, SMS Two-Factor Authentication will be bypassed
REACT_APP_BYPASS_EMAIL=true # If true, email sending will be bypassed

########################################
# 🔴 Socket.IO Configuration
########################################

REACT_APP_SOCKET_URL=http://localhost:3333 # Socket.io connection URL for local development